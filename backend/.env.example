# ---- Database ----
# MySQL connection string used by Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: docker-compose maps MySQL to host port 3307 to avoid clashing with a
# locally-installed MySQL on 3306. Adjust the port if you use your own MySQL.
DATABASE_URL="mysql://root:password@localhost:3307/pms"

# ---- JWT ----
# Use a long, random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# ---- Server ----
PORT=3000
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN="http://localhost:5173"

# ---- Rate limiting ----
# Global cap (requests per minute per IP). The login endpoint is additionally
# limited to 5 requests/minute in code to deter brute-force attacks.
GLOBAL_RATE_LIMIT=120
