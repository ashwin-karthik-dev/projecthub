# =============================================================================
# ProjectHub Backend — Environment Variables
# Copy this file to .env and adjust values for your machine.
# Full documentation: ../docs/ENVIRONMENT.md
# =============================================================================

# ---- Database (required) ----
# MySQL connection string used by Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Docker Compose (MySQL on host port 3307):
#   DATABASE_URL="mysql://root:password@localhost:3307/pms"
# Local MySQL (default port 3306):
#   DATABASE_URL="mysql://root:password@localhost:3306/pms"
DATABASE_URL="mysql://root:password@localhost:3307/pms"

# ---- JWT (required) ----
# Use a long random string in production: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# ---- Server ----
PORT=3000

# Comma-separated frontend origins for CORS.
# If Vite uses another port (e.g. 5174), add it here:
# CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ---- Rate limiting ----
# Global cap (requests per minute per IP). Login is additionally limited to
# 5 requests/minute in code.
GLOBAL_RATE_LIMIT=120
