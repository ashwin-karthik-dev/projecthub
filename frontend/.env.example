# =============================================================================
# ProjectHub Frontend — Environment Variables
# Copy this file to .env before running npm run dev.
# Full documentation: ../docs/ENVIRONMENT.md
# =============================================================================

# Backend API base URL (must include /api prefix).
# Local dev (backend on port 3000):
VITE_API_URL=http://localhost:3000/api

# Production example:
# VITE_API_URL=https://your-api.onrender.com/api
